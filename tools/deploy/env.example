# Required secrets for Kamal deployment
# These go in GitHub repo secrets and/or .kamal/secrets

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Generate with: elixir -e ':crypto.strong_rand_bytes(32) |> Base.encode64() |> IO.puts()'
SETTINGS_ENCRYPTION_KEY=

# GitHub PAT with write:packages scope (for GHCR)
KAMAL_REGISTRY_PASSWORD=

# SSH private key with root access to server
SSH_PRIVATE_KEY=
