# /opt/synkade/.env — copy this file and fill in values
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Generate with: elixir -e ':crypto.strong_rand_bytes(32) |> Base.encode64() |> IO.puts()'
SETTINGS_ENCRYPTION_KEY=

# SQLite database path
DATABASE_PATH=/opt/synkade/synkade.db

# Domain
PHX_HOST=synkade.com
PHX_SERVER=true
PORT=4000

# GitHub webhook secret (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=

# Optional
# POOL_SIZE=5
